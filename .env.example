# ── Public (exposed to browser) ──────────────────────────────────────────────
# Backend API base, read via runtimeConfig.public.apiBase. Public reads
# (useApiFetch) hit this directly.
NUXT_PUBLIC_API_BASE=http://localhost:4000/api/v1

# App info
NUXT_PUBLIC_APP_NAME=Portfolio

# Environment
NUXT_PUBLIC_APP_ENV=development

# ── Server-only (BFF / dashboard, never exposed to the browser) ───────────────
# Reserved for the upcoming admin dashboard. The dashboard will talk to the backend
# through a server-side BFF (Nuxt server routes) that holds httpOnly auth cookies,
# so these are read via useRuntimeConfig() in server routes ONLY. Placeholders —
# no real secrets in this file.

# Internal/private base URL the BFF uses to reach the backend, when it differs from
# the public one (e.g. a private network host or container DNS name). Falls back to
# NUXT_PUBLIC_API_BASE when unset.
# NUXT_API_INTERNAL_BASE=http://localhost:4000/api/v1
