    "@types/node": "^25.0.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "cspell": "^10.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
