    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^0.19.0",
    "vue-tsc": "^3.2.7"
