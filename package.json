{
  "name": "portfolio",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "nuxt dev --dotenv .env.development",
    "prod": "nuxt dev --dotenv .env.production",
    "build": "nuxt build",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fix": "npm run lint:fix && npm run format",
    "typecheck": "nuxi typecheck",
    "spellcheck": "cspell --gitignore --no-progress \"**/*.{ts,tsx,js,jsx,mjs,cjs,vue,md,mdx,json,yml,yaml}\"",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run spellcheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,vue}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.111",
